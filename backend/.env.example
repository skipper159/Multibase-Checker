# Multibase Dashboard API (für MCP / Instance-Management-Tests)
MULTIBASE_API_URL=https://backend.example.com
MULTIBASE_TOKEN=your_multibase_token_here

# Target Instance to test
INSTANCE_NAME=my-project

# Supabase Instance (Standard — URL + Keys reichen jetzt ohne Session-Cookie)
SUPABASE_URL=https://my-project-api.example.com
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Test Server
PORT=3002
